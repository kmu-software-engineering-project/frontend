# ============================================================
# .env.example — 환경 변수 템플릿
# 실제 키 값은 절대 이 파일에 작성하지 않는다.
# 팀원은 이 파일을 복사해 .env.local을 만들고 키를 채운다.
#   cp .env.example .env.local
# ============================================================

# ---- 백엔드 ------------------------------------------------
BACKEND_URL=http://localhost:8000

# ---- 카카오 API --------------------------------------------
# 도서 표지 검색 (서버 전용 — NEXT_PUBLIC_ 접두사 금지)
KAKAO_REST_API_KEY=your-kakao-rest-api-key
# 도서관 지도 (클라이언트 노출 허용)
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=your-kakao-map-app-key
# 레거시 서버 키 (지도 서버 사이드 처리용)
KAKAO_MAP_API_KEY=your-kakao-map-api-key

# ---- 알라딘 Open API ---------------------------------------
# 도서 표지·설명 검색 fallback (서버 전용)
ALADIN_TTB_KEY=your-aladin-ttb-key

# ---- 국립중앙도서관 서지 API --------------------------------
# 장르별 도서 목록 (서버 전용)
NL_SASEO_API_KEY=your-nl-saseo-api-key

# ---- 서울시 공공데이터 API ----------------------------------
# 도서관 위치 정보 (서버 전용)
SEOUL_API_KEY=your-seoul-api-key

# ---- 네이버 검색 API (미사용 / 예비) -----------------------
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ---- 앱 공개 설정 ------------------------------------------
NEXT_PUBLIC_CONTACT_EMAIL=your-email@example.com